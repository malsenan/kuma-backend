# Lumora WhatsApp Cloud API — copy to .env and fill in.
# Get these from the Meta Developer console: developers.facebook.com → your app
# → WhatsApp → API Setup. See docs/SETUP_WHATSAPP.md for a step-by-step guide.

# Permanent access token (System User token; the temporary one expires in 24h)
WHATSAPP_TOKEN=

# The "Phone number ID" of your sending number (NOT the phone number itself)
WHATSAPP_PHONE_NUMBER_ID=

# WhatsApp Business Account (WABA) ID — used for templates/management
WHATSAPP_BUSINESS_ACCOUNT_ID=

# A string YOU invent. You enter the same value in the Meta webhook config;
# Meta echoes it back during verification.
WHATSAPP_VERIFY_TOKEN=change-me-to-a-random-string

# App Secret (App → Settings → Basic). Used to validate webhook signatures.
# Leave blank in local dev to skip signature checks (NOT for production).
WHATSAPP_APP_SECRET=

# Graph API version (optional; defaults to v21.0)
WHATSAPP_GRAPH_API_VERSION=v21.0

# Where to store the SQLite DB and downloaded media (optional; defaults to ./data)
WHATSAPP_DATA_DIR=data
